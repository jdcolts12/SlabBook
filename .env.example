# Copy to .env.local and fill in from Supabase Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side env vars for Vercel Functions (/api/get-insights, /api/estimate-card-value)
# Add these in Vercel Project Settings → Environment Variables
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Default in code: claude-sonnet-4-20250514 (needed for web search + tools). Older models may not support web search.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Optional beta flags (comma-separated) if Anthropic support instructs you to set them
# ANTHROPIC_BETA=
# On Vercel, web search is OFF by default (avoids function timeouts / non-JSON 500). Enable explicitly:
# PRICING_ENABLE_WEB_SEARCH=1
# (PRICING_WEB_SEARCH_EBAY_ONLY=1 or PRICING_WEB_SEARCH_ALLOWED_DOMAINS also enable web search on Vercel.)
# Web search tool: 20250305 (default) or 20260209 for newer models (uses allowed_callers direct-only)
# PRICING_WEB_SEARCH_VERSION=20250305
# Restrict search results to these domains (comma-separated), e.g. ebay.com
# PRICING_WEB_SEARCH_ALLOWED_DOMAINS=ebay.com
# Shorthand for allowed_domains: ebay.com
# PRICING_WEB_SEARCH_EBAY_ONLY=1
# Cap web_search calls per estimate (default 3) to reduce input tokens/min rate limits
# PRICING_WEB_SEARCH_MAX_USES=3
# Retries after Anthropic HTTP 429 (default 2); respects Retry-After when capped by PRICING_429_BACKOFF_CAP_MS
# PRICING_429_MAX_RETRIES=2
# PRICING_429_BACKOFF_CAP_MS=20000
# max_tokens caps (defaults: web 4096, tool-only 2048, JSON fallback 2048)
# PRICING_MAX_OUTPUT_TOKENS_WEB=4096
# PRICING_MAX_OUTPUT_TOKENS_FAST=2048
# PRICING_MAX_OUTPUT_TOKENS_JSON=2048
# If the API rejects tool use, set to 1 to force plain JSON responses only
# PRICING_SKIP_TOOL_USE=1
# Disable Claude web search (eBay) for estimates; uses submit_card_estimate / JSON only
# PRICING_SKIP_WEB_SEARCH=1
# Per Anthropic HTTP call timeout (ms). Optional cap on each request.
# PRICING_ANTHROPIC_TIMEOUT_MS=55000
# Whole-estimate wall (ms). On Vercel, defaults to 52000 if unset so the function returns JSON before the platform hard-kills (~60s Hobby). Set 0 to disable.
# ESTIMATE_MAX_MS=52000
# After a timeout/abort, automatically retry once without web search (default). Set to 1 to disable that retry.
# PRICING_NO_SEARCH_RETRY=1

# Stripe (billing — add to Vercel env; use test keys in development)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_COLLECTOR=
STRIPE_PRICE_INVESTOR=
STRIPE_PRICE_FOUNDING=
# Public site URL for checkout success/cancel (defaults to VERCEL_URL in production)
# APP_ORIGIN=https://your-app.vercel.app

# Optional: welcome email after checkout (https://resend.com)
# RESEND_API_KEY=
# RESEND_FROM=SlabBook <onboarding@yourdomain.com>

# Admin panel at /admin (optional; use a strong password in production)
ADMIN_PASSWORD=
# Optional; defaults to hashing with ADMIN_PASSWORD if unset
# ADMIN_SESSION_SECRET=

