# Copy to .env.local and fill in from Supabase Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side env vars for Vercel Functions (/api/get-insights, /api/fetch-card-value)
# Add these in Vercel Project Settings → Environment Variables
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
RAPIDAPI_KEY=
# Optional override if your RapidAPI eBay host differs:
# RAPIDAPI_EBAY_HOST=real-time-ebay-data.p.rapidapi.com

# Admin panel at /admin (optional; use a strong password in production)
ADMIN_PASSWORD=
# Optional; defaults to hashing with ADMIN_PASSWORD if unset
# ADMIN_SESSION_SECRET=

