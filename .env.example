# Copy to .env.local and fill in from Supabase Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side env vars for Vercel Functions (/api/get-insights, /api/estimate-card-value)
# Add these in Vercel Project Settings → Environment Variables
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Default in code: claude-sonnet-4-20250514 (needed for web search + tools). Older models may not support web search.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Optional beta flags (comma-separated) if Anthropic support instructs you to set them
# ANTHROPIC_BETA=
# Web search tool: 20250305 (default) or 20260209 for newer models (uses allowed_callers direct-only)
# PRICING_WEB_SEARCH_VERSION=20250305
# Restrict search results to these domains (comma-separated), e.g. ebay.com
# PRICING_WEB_SEARCH_ALLOWED_DOMAINS=ebay.com
# Shorthand for allowed_domains: ebay.com
# PRICING_WEB_SEARCH_EBAY_ONLY=1
# If the API rejects tool use, set to 1 to force plain JSON responses only
# PRICING_SKIP_TOOL_USE=1
# Disable Claude web search (eBay) for estimates; uses submit_card_estimate / JSON only
# PRICING_SKIP_WEB_SEARCH=1
# Per Anthropic HTTP call timeout (ms). On Hobby (~60s function cap), try 45000–55000 so you get JSON errors instead of Vercel killing the invocation mid-flight.
# PRICING_ANTHROPIC_TIMEOUT_MS=55000

# Admin panel at /admin (optional; use a strong password in production)
ADMIN_PASSWORD=
# Optional; defaults to hashing with ADMIN_PASSWORD if unset
# ADMIN_SESSION_SECRET=

